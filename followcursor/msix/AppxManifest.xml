<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity
    Name="FollowCursor"
    Publisher="CN=YOURPUBLISHER"
    Version="0.0.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>FollowCursor</DisplayName>
    <PublisherDisplayName>FollowCursor</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>Screen recorder with cinematic cursor-following zoom for tutorials, demos, and walkthroughs.</Description>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="FollowCursor"
      Executable="FollowCursor.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="FollowCursor"
        Description="Screen recorder with cinematic cursor-following zoom"
        BackgroundColor="#1b1a2e"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png" Square310x310Logo="Assets\Square310x310Logo.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" BackgroundColor="#1b1a2e" />
      </uap:VisualElements>
      <Extensions>
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="followcursor-project">
            <uap:DisplayName>FollowCursor Project</uap:DisplayName>
            <uap:SupportedFileTypes>
              <uap:FileType>.fcproj</uap:FileType>
            </uap:SupportedFileTypes>
          </uap:FileTypeAssociation>
        </uap:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
