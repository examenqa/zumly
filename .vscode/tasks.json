			"type": "shell",
			"command": "c:\\Users\\asabbour\\Git\\followcursor\\followcursor\\.venv\\Scripts\\python.exe c:\\Users\\asabbour\\Git\\followcursor\\followcursor\\_profile_startup.py"
		},
		{
