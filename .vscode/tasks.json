{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run",
			"type": "process",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"tray_app.py"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "none",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Start Dev",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/zumly/scripts/Start-Dev.ps1"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "none",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": [],
			"inSessions": true
		},
		{
			"label": "Build",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/zumly/scripts/Build-App.ps1"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Build MSIX (Unsigned)",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/zumly/scripts/Build-Msix.ps1",
				"-Version",
				"${input:msixVersion}",
				"-SkipSign"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"dependsOn": "Build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Build MSIX (Signed with PFX)",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/zumly/scripts/Build-Msix.ps1",
				"-Version",
				"${input:msixVersion}",
				"-Publisher",
				"${input:msixPublisher}",
				"-LocalPfx",
				"${input:pfxPath}",
				"-PfxPassword",
				"${input:pfxPassword}"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"dependsOn": "Build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Install Dependencies",
			"type": "process",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pip",
				"install",
				"-r",
				"requirements.txt"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Run Tests",
			"type": "process",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pytest",
				"zumly/tests/",
				"-v",
				"--tb=short"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Create Dev Signing Certificate",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$certsDir = Join-Path '${workspaceFolder}' '.certs'; if (-not (Test-Path $certsDir)) { New-Item -ItemType Directory -Path $certsDir -Force | Out-Null }; $cert = New-SelfSignedCertificate -Type Custom -Subject 'CN=Zumly-Dev' -KeyUsage DigitalSignature -FriendlyName 'Zumly Dev' -CertStoreLocation 'Cert:\\CurrentUser\\My' -TextExtension @('2.5.29.37={text}1.3.6.1.5.5.7.3.3'); $cerPath = Join-Path $certsDir 'Zumly-Dev.cer'; $pfxPath = Join-Path $certsDir 'Zumly-Dev.pfx'; Export-Certificate -Cert $cert -FilePath $cerPath; Import-Certificate -FilePath $cerPath -CertStoreLocation 'Cert:\\CurrentUser\\TrustedPeople'; Export-PfxCertificate -Cert $cert -FilePath $pfxPath -Password (ConvertTo-SecureString -String 'dev' -Force -AsPlainText); Write-Host \"`nCertificate created and trusted.`nPFX path: $pfxPath`nPublisher: CN=Zumly-Dev`nPassword: dev\" -ForegroundColor Green"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": [],
			"runOptions": {
				"runOn": "default"
			}
		}
	],
	"inputs": [
		{
			"id": "msixVersion",
			"type": "promptString",
			"description": "MSIX version (e.g. 0.5.0)",
			"default": "0.5.0"
		},
		{
			"id": "msixPublisher",
			"type": "promptString",
			"description": "Certificate subject (e.g. CN=Name, O=Org, L=City, S=State, C=US)",
			"default": "CN=Zumly-Dev"
		},
		{
			"id": "pfxPath",
			"type": "promptString",
			"description": "Path to .pfx certificate file",
			"default": "${workspaceFolder}/.certs/Zumly-Dev.pfx"
		},
		{
			"id": "pfxPassword",
			"type": "promptString",
			"description": "PFX certificate password",
			"default": "dev",
			"password": true
		}
	]
}
