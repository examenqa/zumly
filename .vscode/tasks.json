{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run",
			"type": "process",
			"command": "${workspaceFolder}/followcursor/.venv/Scripts/python.exe",
			"args": [
				"main.py"
			],
			"options": {
				"cwd": "${workspaceFolder}/followcursor"
			},
			"group": "none",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Start Dev",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/followcursor/scripts/Start-Dev.ps1"
			],
			"options": {
				"cwd": "${workspaceFolder}/followcursor"
			},
			"group": "none",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Build",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/followcursor/scripts/Build-App.ps1"
			],
			"options": {
				"cwd": "${workspaceFolder}/followcursor"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Build MSIX (Unsigned)",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/followcursor/scripts/Build-Msix.ps1",
				"-Version",
				"${input:msixVersion}",
				"-SkipSign"
			],
			"options": {
				"cwd": "${workspaceFolder}/followcursor"
			},
			"group": "build",
			"dependsOn": "Build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Build MSIX (Signed with PFX)",
			"type": "process",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/followcursor/scripts/Build-Msix.ps1",
				"-Version",
				"${input:msixVersion}",
				"-Publisher",
				"${input:msixPublisher}",
				"-LocalPfx",
				"${input:pfxPath}"
			],
			"options": {
				"cwd": "${workspaceFolder}/followcursor"
			},
			"group": "build",
			"dependsOn": "Build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Install Dependencies",
			"type": "process",
			"command": "${workspaceFolder}/followcursor/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pip",
				"install",
				"-r",
				"requirements.txt"
			],
			"options": {
				"cwd": "${workspaceFolder}/followcursor"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Run Tests",
			"type": "process",
			"command": "${workspaceFolder}/followcursor/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pytest",
				"tests/",
				"-v",
				"--tb=short"
			],
			"options": {
				"cwd": "${workspaceFolder}/followcursor"
			},
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "msixVersion",
			"type": "promptString",
			"description": "MSIX version (e.g. 0.5.0)",
			"default": "0.5.0"
		},
		{
			"id": "msixPublisher",
			"type": "promptString",
			"description": "Certificate subject (e.g. CN=Name, O=Org, L=City, S=State, C=US)",
			"default": "CN=FollowCursor-Dev"
		},
		{
			"id": "pfxPath",
			"type": "promptString",
			"description": "Path to .pfx certificate file"
		}
	]
}