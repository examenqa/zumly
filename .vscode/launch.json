{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Zumly Tray",
			"type": "debugpy",
			"request": "launch",
			"program": "tray_app.py",
			"cwd": "${workspaceFolder}",
			"python": "${workspaceFolder}/.venv/Scripts/python.exe",
			"console": "integratedTerminal",
			"justMyCode": true
		},
		{
			"name": "Debug Zumly Capture Worker",
			"type": "debugpy",
			"request": "launch",
			"program": "zumly/main.py",
			"cwd": "${workspaceFolder}",
			"python": "${workspaceFolder}/.venv/Scripts/python.exe",
			"console": "integratedTerminal",
			"justMyCode": false
		}
	]
}
